{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$defs": {
    "id_and_description": {
      "type": "object",
      "required": [
        "id",
        "description"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "threshold": {
      "type": "object",
      "required": [
        "metric_id",
        "comparison",
        "target",
        "owner"
      ],
      "properties": {
        "metric_id": {
          "type": "string",
          "minLength": 1
        },
        "comparison": {
          "type": "string",
          "enum": [
            "<",
            "<=",
            "=",
            ">=",
            ">"
          ]
        },
        "target": {
          "type": "number"
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "escalate_to": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "action": {
          "type": "string"
        }
      }
    },
    "review_gate_selection": {
      "type": "object",
      "required": [
        "gate",
        "applies_when",
        "minimum_evidence"
      ],
      "properties": {
        "gate": {
          "type": "string",
          "minLength": 1
        },
        "applies_when": {
          "type": "string",
          "minLength": 1
        },
        "minimum_evidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "review_pipeline": {
      "type": "object",
      "required": [
        "purpose",
        "owner",
        "default_order",
        "gate_selection",
        "learning_loop"
      ],
      "properties": {
        "purpose": {
          "type": "string",
          "minLength": 1
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "default_order": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "gate_selection": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/review_gate_selection"
          }
        },
        "learning_loop": {
          "type": "object",
          "required": [
            "owner",
            "event_type",
            "runtime_path",
            "tracked_truth_rule",
            "capture_when"
          ],
          "properties": {
            "owner": {
              "type": "string",
              "minLength": 1
            },
            "event_type": {
              "type": "string",
              "minLength": 1
            },
            "runtime_path": {
              "type": "string",
              "minLength": 1
            },
            "tracked_truth_rule": {
              "type": "string",
              "minLength": 1
            },
            "capture_when": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    "tool_plane_policy": {
      "type": "object",
      "required": [
        "purpose",
        "owner",
        "default_rule",
        "required_request_fields",
        "sensitive_tool_classes",
        "rules"
      ],
      "properties": {
        "purpose": {
          "type": "string",
          "minLength": 1
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "default_rule": {
          "type": "string",
          "minLength": 1
        },
        "required_request_fields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "sensitive_tool_classes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "rules": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "run_receipts_and_provenance": {
      "type": "object",
      "required": [
        "owner",
        "runtime_paths",
        "receipt_required_for",
        "minimum_receipt_fields",
        "provenance_edges",
        "tracked_truth_rule"
      ],
      "properties": {
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "runtime_paths": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "string",
            "minLength": 1
          }
        },
        "receipt_required_for": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "minimum_receipt_fields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "provenance_edges": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "tracked_truth_rule": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "agent_release_discipline": {
      "type": "object",
      "required": [
        "owner",
        "applies_when",
        "required_release_evidence",
        "rollback_rule"
      ],
      "properties": {
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "applies_when": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "required_release_evidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "rollback_rule": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "subagent_context_protocol": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "owner",
        "applies_to_roles",
        "inherit_parent_history",
        "require_explicit_context_packet",
        "require_original_source_material",
        "context_packet_sections",
        "required_packet_fields",
        "return_handoff_requirements",
        "child_session_defaults"
      ],
      "properties": {
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "applies_to_roles": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "inherit_parent_history": {
          "type": "boolean"
        },
        "require_explicit_context_packet": {
          "type": "boolean"
        },
        "require_original_source_material": {
          "type": "boolean"
        },
        "context_packet_sections": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "required_packet_fields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "return_handoff_requirements": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "child_session_defaults": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "scope",
            "blocked_tool_classes"
          ],
          "properties": {
            "scope": {
              "type": "string",
              "enum": [
                "child_isolated"
              ]
            },
            "blocked_tool_classes": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    }
  },
  "type": "object",
  "required": [
    "version",
    "updated_at",
    "stage",
    "autonomy_tiers",
    "risk_tiers",
    "approvals",
    "weekly_metric_review",
    "eval_policy",
    "subagent_context_protocol",
    "metric_thresholds"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "updated_at": {
      "type": "string",
      "format": "date"
    },
    "stage": {
      "type": "string",
      "minLength": 1
    },
    "autonomy_tiers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/id_and_description"
      }
    },
    "risk_tiers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "allOf": [
          {
            "$ref": "#/$defs/id_and_description"
          },
          {
            "type": "object",
            "required": [
              "default_approval"
            ],
            "properties": {
              "default_approval": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        ]
      }
    },
    "approvals": {
      "type": "object",
      "required": [
        "human_only_actions",
        "governor_review_required_for",
        "default_spend_without_budget_eur",
        "max_external_send_without_review"
      ]
    },
    "weekly_metric_review": {
      "type": "object",
      "required": [
        "cadence",
        "owner",
        "support",
        "approver",
        "required_metrics"
      ]
    },
    "eval_policy": {
      "type": "object",
      "required": [
        "minimum_checks_for_repeated_work",
        "control_plane_change_requires"
      ]
    },
    "review_pipeline": {
      "$ref": "#/$defs/review_pipeline"
    },
    "runtime_governance": {
      "type": "object",
      "required": [
        "policy_surface",
        "hook_events"
      ]
    },
    "tool_plane_policy": {
      "$ref": "#/$defs/tool_plane_policy"
    },
    "run_receipts_and_provenance": {
      "$ref": "#/$defs/run_receipts_and_provenance"
    },
    "agent_release_discipline": {
      "$ref": "#/$defs/agent_release_discipline"
    },
    "subagent_context_protocol": {
      "$ref": "#/$defs/subagent_context_protocol"
    },
    "metric_thresholds": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/threshold"
      }
    }
  }
}
