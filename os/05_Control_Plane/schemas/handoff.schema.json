{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "entity_type",
    "id",
    "thread_id",
    "mission_id",
    "run_id",
    "task",
    "session",
    "owner",
    "status",
    "accepting_role",
    "continue_from",
    "spec_file",
    "primary_file",
    "handoff_path",
    "read_first",
    "done_items",
    "next_steps",
    "important_files",
    "risks",
    "blockers",
    "notes",
    "created_at",
    "updated_at",
    "metadata"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "entity_type": {
      "type": "string",
      "const": "handoff"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "thread_id": {
      "type": "string",
      "minLength": 1
    },
    "mission_id": {
      "type": "string"
    },
    "run_id": {
      "type": "string"
    },
    "task": {
      "type": "string",
      "minLength": 1
    },
    "session": {
      "type": "string",
      "minLength": 1
    },
    "owner": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "ready_for_handoff",
        "in_progress",
        "paused",
        "completed",
        "blocked",
        "cancelled"
      ]
    },
    "accepting_role": {
      "type": "string"
    },
    "continue_from": {
      "type": "string"
    },
    "spec_file": {
      "type": "string"
    },
    "primary_file": {
      "type": "string"
    },
    "handoff_path": {
      "type": "string",
      "minLength": 1
    },
    "read_first": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "done_items": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "next_steps": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "important_files": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "metadata": {
      "type": "object"
    }
  }
}
