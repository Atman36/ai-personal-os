{
  "version": 1,
  "updated_at": "2026-06-11",
  "principal_contract": {
    "purpose": "Make one human owner explicit for every material task, approval, and accepted result.",
    "required_identity_fields": [
      "owner",
      "manager",
      "accepts_result",
      "risk_tier",
      "autonomy_tier"
    ],
    "default_constraints": [
      "Use Russian in chat unless the user asks otherwise.",
      "Prefer one next move over a menu of options.",
      "Never perform external sends, spending, deletion, legal/public commitments, or credential changes without explicit approval."
    ]
  },
